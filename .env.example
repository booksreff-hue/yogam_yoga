# ======================
# Server-side (do NOT prefix with VITE_)
# ======================

# Google Places API (Place Details)
GOOGLE_API_KEY=
GOOGLE_PLACE_ID=

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
